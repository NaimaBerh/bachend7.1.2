# =============================================================================
#  Variables d'environnement du backend FakeGuard / FPD
# =============================================================================
#  Copiez ce fichier en .env et adaptez-le à votre installation.
#  Sous Linux/macOS  :  cp .env.example .env
#  Sous Windows PS   :  Copy-Item .env.example .env
# =============================================================================

# Port d'écoute Flask (par défaut 5000)
PORT=5000

# Origines CORS autorisées (séparées par des virgules)
# Pour autoriser tout le monde en local : *
ALLOWED_ORIGINS=*

# Seuil de classification du LSTM (au-dessus = "fake")
LSTM_THRESHOLD=0.5

# Timeout (s) pour l'extraction d'URL
HTTP_TIMEOUT=15

# Token GitHub optionnel pour passer le quota API publique de 60 -> 5000 req/h
# https://github.com/settings/tokens (un token "fine-grained" avec lecture publique suffit)
GITHUB_TOKEN=
